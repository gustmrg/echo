# Copy to `.env` in the project root (docker compose loads it automatically).
# Used by docker-compose.yml for the API connection string and Postgres/MinIO credentials.

# PostgreSQL
POSTGRES_USER=app
POSTGRES_PASSWORD=

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# Worker S3/MinIO access
S3_BUCKET=echo-files
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=true
