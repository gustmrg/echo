# Copy to `.env` in the project root (docker compose loads it automatically).
# Used by docker-compose.yml for MinIO credentials and worker transcription.

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# Worker transcription
TRANSCRIPTION_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TRANSCRIPTION_MODEL=openai/gpt-4o-mini-transcribe

# Required only when TRANSCRIPTION_PROVIDER=openai
OPENAI_API_KEY=

# Worker S3/MinIO access
DB_PATH=/data/echo.db
S3_BUCKET=echo-files
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=true
